# crCheckIn 环境变量配置
# 复制此文件为 .env 并填入实际值

# 必填：Session 密钥（用于加密签名），长度至少 32 个字符；生产环境请使用强随机字符串
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=

# PostgreSQL 数据库连接地址
DATABASE_URL="postgresql://crcheckin_user:CHANGE_ME@127.0.0.1:5432/crcheckin?schema=public"
# Windows 可选：PostgreSQL 备份工具路径
# PG_DUMP_PATH="C:\Program Files\PostgreSQL\17\bin\pg_dump.exe"

# 服务端口（默认 5000）
PORT=5000

# 监听地址（默认 0.0.0.0）
HOST=0.0.0.0

# 小题成绩处理使用的 Python，可留空使用系统 python
# 该 Python 环境需要安装 pandas、openpyxl 等表格处理依赖
# EXAM_ANALYSIS_PYTHON=C:\Python311\python.exe
