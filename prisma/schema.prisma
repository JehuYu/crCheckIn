generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Teacher {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  classes      Class[]
}

model Class {
  id            Int            @id @default(autoincrement())
  name          String
  teacherId     Int
  teacher       Teacher        @relation(fields: [teacherId], references: [id])
  createdAt     DateTime       @default(now())
  students      Student[]
  signInConfig  SignInConfig?
  signInRecords SignInRecord[]
  sessions      SignInSession[]

  @@unique([teacherId, name])
}

model SignInSession {
  id        Int            @id @default(autoincrement())
  classId   Int
  class     Class          @relation(fields: [classId], references: [id])
  label     String         // 如 "2025-03-18 周二 上午 · 一职B4"
  archivedAt DateTime      @default(now())
  records   ArchivedRecord[]
}

model ArchivedRecord {
  id           Int           @id @default(autoincrement())
  sessionId    Int
  session      SignInSession @relation(fields: [sessionId], references: [id])
  studentName  String
  homeClass    String        @default("")
  computerName String
  signedAt     DateTime
}

model Student {
  id            Int           @id @default(autoincrement())
  name          String
  homeClass     String        @default("")   // 行政班级，如"高一3班"
  classId       Int
  class         Class         @relation(fields: [classId], references: [id])
  signInRecords SignInRecord[]

  @@unique([classId, name])
}

model SignInRecord {
  id           Int      @id @default(autoincrement())
  studentName  String
  computerName String
  signedAt     DateTime @default(now())
  classId      Int
  class        Class    @relation(fields: [classId], references: [id])
  studentId    Int?
  student      Student? @relation(fields: [studentId], references: [id])

  @@unique([classId, studentName])
}

model SignInConfig {
  id        Int       @id @default(autoincrement())
  classId   Int       @unique
  class     Class     @relation(fields: [classId], references: [id])
  startTime DateTime?
  endTime   DateTime?
}
